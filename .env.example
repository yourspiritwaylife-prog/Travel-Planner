# ============================================================
#  Travel Planner — налаштування (скопіюй цей файл у ".env")
# ============================================================
#  Це ОКРЕМИЙ бот. Він використовує існуючий Hermes Agent (через CLI)
#  і НЕ чіпає інший (AI-News) бот та його токен.
# ============================================================

# --- Telegram: окремий токен САМЕ для Travel Planner бота ---
# Отримати у @BotFather для НОВОГО бота (не плутати з AI-News!)
TRAVEL_TELEGRAM_BOT_TOKEN=

# --- Мозок: існуючий Hermes Agent через CLI ---
# "hermes" — основний; "mock" — офлайн-демо карток без Hermes
BRAIN=hermes

# --- Hermes CLI ---
# Команда виклику: `hermes -z "<prompt>"`
HERMES_BIN=hermes
HERMES_FLAG=-z
HERMES_TIMEOUT=180

# Режим виклику Hermes:
#   • порожньо — бот працює НА ТОМУ Ж сервері, що й Hermes → кличе напряму
#   • "root@144.126.206.226" — бот працює на ІНШІЙ машині (розробка),
#     тоді hermes викликається через SSH. Потрібен налаштований SSH-ключ
#     (passwordless), бо пароль вводити нікому.
HERMES_SSH=

# --- Безкоштовні джерела даних (ключі НЕ потрібні) ---
# OpenStreetMap / Wikipedia працюють без ключів.
OSM_CONTACT_EMAIL=yourspiritway.life@gmail.com
