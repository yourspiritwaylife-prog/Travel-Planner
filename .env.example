# ============================================================
#  Travel Planner — налаштування (скопіюй цей файл у ".env")
# ============================================================
#  Тобі НЕ треба заповнювати все одразу.
#  Мінімум для запуску: TELEGRAM_BOT_TOKEN + один "мозок".
# ============================================================

# --- Telegram (обовʼязково) ---
# Отримати безкоштовно у @BotFather: напиши йому /newbot
TELEGRAM_BOT_TOKEN=

# --- Який "мозок" використовувати: "gemini" або "hermes" ---
BRAIN=gemini

# --- Варіант 1: Gemini (безкоштовно) ---
# Ключ безкоштовно тут: https://aistudio.google.com/app/apikey
# Має починатися з "AIza..."
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Варіант 2: існуючий Hermes на DigitalOcean ---
# Заповнюємо пізніше, коли розберемося з його адресою
HERMES_URL=
HERMES_API_KEY=

# --- Безкоштовні джерела даних (ключі НЕ потрібні) ---
# OpenStreetMap / Wikivoyage / Wikimedia працюють без ключів.
# Контактний email потрібен правилами OSM (будь-який твій email):
OSM_CONTACT_EMAIL=yourspiritway.life@gmail.com
