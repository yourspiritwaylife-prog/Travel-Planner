# ============================================================
#  Travel agent — локальне .env (скопіюй цей файл у ".env")
# ============================================================
#  Живий бот — це Hermes-агент (профіль `travel`) на сервері.
#  Цей .env потрібен лише для ЛОКАЛЬНОГО прогону/прев'ю скриптів
#  (preview.py, _dayplan_server.py, _viator_server.py).
#  На сервері реальні значення лежать у профілі .env агента.
# ============================================================

# --- Google Places (реальні фото/рейтинги/години/ціни для сторінки дня) ---
# Ключ Maps-restricted, працює для Places. Без нього сторінка будується,
# але без фото й рейтингів.
GOOGLE_PLACES_API_KEY=

# --- Telegram (куди _dayplan_server.py надсилає готову сторінку дня) ---
# Потрібні лише якщо надсилаєш із локальної машини; зазвичай шле сервер.
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=

# --- Viator (партнерські тури/квитки для _viator_server.py) ---
VIATOR_API_KEY=
